# ============ Backend ============
APP_ENV=development
LOG_LEVEL=INFO
LOG_JSON=false

API_HOST=0.0.0.0
API_PORT=8000

# Model registry YAML (default model + list of available impls)
MODELS_CONFIG_PATH=./models.yaml

# Max concurrent inference calls served from the active model
DETECTOR_MAX_PARALLEL=4

# Max time a request waits to acquire an inference slot before 429
DETECTOR_QUEUE_TIMEOUT_S=10

# Margin around 0.5 classified as `unknown`
DETECTOR_UNKNOWN_MARGIN=0.05

# ============ Bot ============
BOT_TOKEN=replace-with-your-telegram-bot-token
BACKEND_BASE_URL=http://localhost:8000
BACKEND_TIMEOUT_READ=30
BACKEND_RETRIES=3

# polling | webhook
BOT_MODE=polling

# Comma-separated list of Telegram user IDs allowed to run admin commands (optional)
ADMIN_USER_IDS=
